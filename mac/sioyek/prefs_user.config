# sioyek-python-tools (sioyek==0.31.11) installed in a dedicated venv.
# Use the venv's absolute python: GUI apps don't inherit shell PATH, and there
# is no bare `python` on this machine (only python3).
new_command _download_paper /Users/induja/.venvs/sioyek-tools/bin/python -m sioyek.paper_downloader download "%{sioyek_path}" "%{paper_name}" "%{selected_text}" ic.induja@gmail.com
control_click_command _download_paper
new_command _dual_panelify /Users/induja/.venvs/sioyek-tools/bin/python -m sioyek.dual_panelify "%{sioyek_path}" "%{file_path}" "%{command_text}"
new_command _extract_highlights /Users/induja/.venvs/sioyek-tools/bin/python -m sioyek.extract_highlights "%{sioyek_path}" "%{local_database}" "%{shared_database}" "%1" %{zoom_level}
new_command _add_text /Users/induja/.venvs/sioyek-tools/bin/python -m sioyek.add_text "%{sioyek_path}" "%{local_database}" "%{shared_database}" "%{file_path}" "%{selected_rect}" "%{command_text}"
new_command _add_red_text /Users/induja/.venvs/sioyek-tools/bin/python -m sioyek.add_text "%{sioyek_path}" "%{local_database}" "%{shared_database}" "%{file_path}" "%{selected_rect}" "%{command_text}" fontsize=5 text_color=255,0,0

# Side-by-side layout, tiled to fill a 1440x900 logical workspace.
# Two 718pt columns below the ~25pt menu bar, no overlap, no wasted margin.
# main_window_* = where the MAIN window goes once the helper opens.
main_window_size 718 846
main_window_move 0 28
helper_window_size 718 846
helper_window_move 720 28

# When NO helper window is open, the lone main window fills the whole screen
# (maximized, not true fullscreen — menu bar stays visible).
single_main_window_size 1440 846
single_main_window_move 0 28